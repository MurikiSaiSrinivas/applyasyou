{
  "manifest_version": 3,
  "name": "Job Scraper Companion (local)",
  "version": "1.0.0",
  "description": "Scrape-only job harvester: Google Jobs, Wellfound, and LinkedIn (search/saved/applied) with tab-based JD fetch, plus a LinkedIn post-URL classifier. Auto-runs filters + heuristic scoring at the local sink. Bridged via 127.0.0.1:8765.",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "http://*/*",
    "https://*/*",
    "http://localhost:8765/*",
    "http://127.0.0.1:8765/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "Job Scraper Companion"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://www.google.com/search*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://wellfound.com/*"],
      "js": ["content_wellfound.js"],
      "run_at": "document_idle"
    },
    {
      "matches": ["https://www.linkedin.com/*", "https://linkedin.com/*"],
      "js": ["content_linkedin.js"],
      "run_at": "document_idle"
    }
  ]
}
